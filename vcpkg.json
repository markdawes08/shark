{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "shark",
  "version-string": "0.0.0",
  "description": "Pinned third-party foundation for the Shark engine",
  "supports": "windows & x64",
  "dependencies": [
    "catch2",
    {
      "name": "directx-dxc",
      "host": true
    },
    "directx-headers",
    "directx12-agility",
    "directx-warp",
    "directxmath",
    {
      "name": "directxtex",
      "default-features": false,
      "features": [
        "dx12",
        "tools"
      ]
    },
    "spdlog",
    "winpixevent"
  ],
  "overrides": [
    {
      "name": "directx-dxc",
      "version-date": "2026-05-27"
    }
  ]
}
